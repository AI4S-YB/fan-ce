{
    "api": {
        "base_url": "http://localhost:8889",
        "api_prefix": "/api/v1",
        "timeout": 30,
        "retry_count": 3,
        "retry_delay": 1
    },
    "auth": {
        "token_type": "Bearer",
        "token_header": "Authorization",
        "username": "admin",
        "password": "admin"
    },
    "logging": {
        "enabled": true,
        "level": "INFO",
        "log_file": null,
        "max_bytes": 10485760,
        "backup_count": 5,
        "console_enabled": true,
        "file_enabled": true,
        "api_logging_enabled": true,
        "error_logging_enabled": true
    },
    "cache": {
        "enabled": true,
        "ttl": 300,
        "max_size": 1000
    },
    "database": {
        "type": "postgresql",
        "host": "localhost",
        "port": 5432,
        "name": "abd_db",
        "username": "db_user",
        "password": "db_password",
        "pool_size": 10,
        "connect_timeout": 10
    },
    "storage": {
        "type": "local",
        "local_path": "./data",
        "s3": {
            "bucket": "abd-bucket",
            "region": "us-east-1",
            "access_key": "your_access_key",
            "secret_key": "your_secret_key"
        },
        "minio": {
            "endpoint": "localhost:9000",
            "access_key": "minioadmin",
            "secret_key": "minioadmin",
            "bucket": "abd-bucket"
        }
    },
    "security": {
        "verify_ssl": true,
        "ca_cert": null,
        "client_cert": null,
        "client_key": null,
        "proxy": {
            "http": null,
            "https": null
        }
    },
    "performance": {
        "connection_pool_size": 20,
        "max_concurrent_requests": 100,
        "request_queue_size": 1000,
        "heartbeat_interval": 30
    },
    "monitoring": {
        "enabled": false,
        "collection_interval": 60,
        "health_check": false,
        "health_check_interval": 300
    },
    "development": {
        "debug": false,
        "verbose": false,
        "profiling": false,
        "test_mode": false
    },
    "environments": {
        "development": {
            "api": {
                "base_url": "http://localhost:8002"
            },
            "logging": {
                "level": "DEBUG",
                "console_enabled": true,
                "file_enabled": false
            }
        },
        "testing": {
            "api": {
                "base_url": "http://test-server:8001"
            },
            "logging": {
                "level": "INFO",
                "console_enabled": true,
                "file_enabled": true,
                "log_file": "./logs/test.log"
            }
        },
        "production": {
            "api": {
                "base_url": "https://api.abd.com"
            },
            "logging": {
                "level": "WARNING",
                "console_enabled": false,
                "file_enabled": true,
                "log_file": "/var/log/abd_sdk.log",
                "api_logging_enabled": false,
                "error_logging_enabled": true
            }
        }
    }
}
