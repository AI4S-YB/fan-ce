FROM dockers.percent.cn/os/rockylinux/rockylinux:8.10
USER root

WORKDIR /opt/cloud
ADD  . /opt/cloud

EXPOSE 8000
EXPOSE 8866

ENV LANG=en_US
ENV LC_ALL=en_US.UTF-8
ENV PROJECT_DIR=/opt/cloud
ENV PGSQL_PORT 5432
ENV PGSQL_HOST 127.0.0.1
ENV PGSQL_USER bfdadmin
ENV PGSQL_PASSWORD bfd123
ENV PGSQL_DATABASE oma
RUN set -ex \
    && yum  install glibc-langpack-en python39 -y \
    && pip3 install  -r requirements.txt -i http://mirrors.aliyun.com/pypi/simple/ --trusted-host mirrors.aliyun.com

WORKDIR /opt/cloud
#CMD ["python3","main.py"]
