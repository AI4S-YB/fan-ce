# 应用标题
VITE_APP_TITLE=FAN-CE

# 应用命名空间（缓存、store 前缀，确保隔离）
VITE_APP_NAMESPACE=FanCE

# Store 加密密钥（localStorage 持久化加密用）
VITE_APP_STORE_SECURE_KEY=FAN-CE

# 开发端口（仅 dev 模式生效）
VITE_PORT=5666

# 基础路径
VITE_BASE=/

# API 接口地址
VITE_GLOB_API_URL=/api/v1

# 注入全局 loading
VITE_INJECT_APP_LOADING=false

# 构建产物压缩：none / brotli / gzip（仅 production 生效）
VITE_COMPRESS=none

# 是否开启 PWA（仅 production 生效）
VITE_PWA=false

# vue-router 模式：hash / history
VITE_ROUTER_HISTORY=none

# 打包后生成 dist.zip（仅 production 生效）
VITE_ARCHIVER=true
