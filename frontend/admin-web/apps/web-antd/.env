# ── 应用标识 ──
VITE_APP_TITLE=FAN-CE
VITE_APP_NAMESPACE=FanCE

# Store 加密密钥（Pinia 持久化到 localStorage 时加密用）
VITE_APP_STORE_SECURE_KEY=FAN-CE

# API 接口地址（请求代理基础路径）
VITE_GLOB_API_URL=/api/v1

# vue-router 模式：hash / history
VITE_ROUTER_HISTORY=none

# PWA Service Worker（false = 关闭）
VITE_PWA=false

# ── 仅开发模式 (pnpm dev) ──
# Dev server 端口，生产构建时 nginx 处理
VITE_PORT=5666

# ── 以下已被 application.ts 硬编码覆盖，env 值不生效 ──
# VITE_BASE=/                          → 硬编码 getString(VITE_BASE, '/')
# VITE_INJECT_APP_LOADING=false        → 硬编码 injectAppLoading: true
# VITE_COMPRESS=none                   → 硬编码 compress: false
# VITE_ARCHIVER=true                   → 硬编码 archiver: true
